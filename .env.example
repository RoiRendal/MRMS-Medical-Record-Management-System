# MRMS server
PORT=9100

# Local MRMS database (doctor profiles, availability, optional link tables)
MRMS_DB_URI=mongodb://127.0.0.1:27017/mrms

# Adapter Layer (Hospital legacy access) — leave empty + set ADAPTER_USE_MOCK=true for local dev without adapter
ADAPTER_BASE_URL=
ADAPTER_USE_MOCK=true

# Authentication & Authorization service
AUTH_BASE_URL=
AUTH_USE_MOCK=true
